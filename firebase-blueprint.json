{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Stores user profile and role information.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["normal", "premium", "admin"] },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "name", "email", "role", "createdAt", "updatedAt"]
    },
    "PaymentRequest": {
      "title": "PaymentRequest",
      "description": "Stores manual payment requests for premium upgrades.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "amount": { "type": "number" },
        "planId": { "type": "string" },
        "planName": { "type": "string" },
        "transferCode": { "type": "string" },
        "screenshotUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "userId", "userName", "userEmail", "amount", "planId", "planName", "transferCode", "status", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile document."
    },
    "/paymentRequests/{requestId}": {
      "schema": "PaymentRequest",
      "description": "Manual payment request document."
    }
  }
}
