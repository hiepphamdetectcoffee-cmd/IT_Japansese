rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "hieppham.detectcoffee@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'role', 'createdAt', 'updatedAt']) &&
             data.id is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string &&
             data.role in ['normal', 'premium', 'admin'] &&
             data.createdAt is number &&
             data.updatedAt is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Only allow users to create their own profile as 'normal' initially, or admin can create any
      allow create: if (isOwner(userId) && request.resource.data.role == 'normal' && isValidUser(request.resource.data)) || isAdmin();
      
      // Only allow users to update their own profile (but not change their role), or admin can update anything
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role && isValidUser(request.resource.data)) || isAdmin();
      
      allow delete: if isAdmin();
    }

    match /paymentRequests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == 'pending' &&
        request.resource.data.keys().hasAll(['id', 'userId', 'userName', 'userEmail', 'amount', 'planId', 'planName', 'transferCode', 'status', 'createdAt', 'updatedAt']);
      allow update, delete: if isAdmin();
    }
  }
}
